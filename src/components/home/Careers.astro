---
import { Icon } from 'astro-icon/components';
---

<section id="careers" class="py-50 bg-gradient-purple-blue text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <Icon name="ph:hands-clapping" size={48} class="mx-auto mb-4 opacity-90" />
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">Join Our Caregiving Team</h2>
    <p class="text-lg opacity-90 max-w-2xl mx-auto mb-8">
        We're looking for compassionate individuals who want to make a real difference in the lives of families around the LA area.
    </p>
    <p class="text-lg opacity-90 max-w-2xl mx-auto mb-8">
        Competitive pay, flexible schedules, and meaningful work.
    </p>
    <a
        href="#contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white text-secondary-purple font-semibold rounded-full hover:bg-gray-100 transition-colors"
    >
        View Open Positions
        <Icon name="ph:arrow-right" size={20} />
    </a>
    </div>
</section>