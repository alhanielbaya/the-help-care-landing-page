---
import { Icon } from 'astro-icon/components';
---


<section id="contact" class="py-16 md:py-24 animate-fade-in-up">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">
            Let's Start the Conversation
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Ready to learn more? Contact us today for a free, no-obligation consultation. We're here to answer your questions.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-teal-lime rounded-full flex items-center justify-center flex-shrink-0">
                <Icon name="ph:phone" size={24} class="text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Phone</h3>
                <p class="text-gray-600">
                  <a href="tel:+18185551234" class="hover:text-secondary-purple transition-colors">(818) 555-1234</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-purple-blue rounded-full flex items-center justify-center flex-shrink-0">
                <Icon name="ph:envelope-simple" size={24} class="text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Email</h3>
                <p class="text-gray-600">
                  <a href="mailto:care@thehelpcare.com" class="hover:text-secondary-purple transition-colors">care@thehelpcare.com</a>
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-teal-lime rounded-full flex items-center justify-center flex-shrink-0">
                <Icon name="ph:map-pin" size={24} class="text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Service Area</h3>
                <p class="text-gray-600">15755 Saticoy St.<br />Los Angeles County, CA</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-gradient-purple-blue rounded-full flex items-center justify-center flex-shrink-0">
                <Icon name="ph:clock" size={24} class="text-white" />
              </div>
              <div>
                <h3 class="font-semibold text-lg mb-1">Availability</h3>
                <p class="text-gray-600">24/7 Care Available<br />Office: Mon-Fri 8am-6pm</p>
              </div>
            </div>
          </div>

          <div>
            <form class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Your Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary-purple focus:border-transparent outline-none transition-shadow"
                  placeholder="John Smith"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary-purple focus:border-transparent outline-none transition-shadow"
                  placeholder="john@example.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary-purple focus:border-transparent outline-none transition-shadow"
                  placeholder="(818) 123-4567"
                />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">How Can We Help?</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-secondary-purple focus:border-transparent outline-none transition-shadow resize-none"
                  placeholder="Tell us about your care needs..."
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full py-4 bg-gradient-purple-blue text-white font-semibold rounded-lg hover:opacity-90 transition-opacity flex items-center justify-center gap-2"
              >
                <Icon name="ph:chat-circle-text" size={20} />
                Request a Free Consultation
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>